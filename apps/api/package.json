{
  "name": "@xiaolanbu/api",
  "version": "0.1.0",
  "private": true,
  "description": "Xiaolanbu backend API",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "dev:worker": "ts-node-dev --respawn --transpile-only src/worker.main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:worker": "node dist/worker.main.js",
    "test:account-billing": "npm run build && node --test test/account-billing.test.cjs",
    "test:local-device-deployments": "npm run build && node --test test/local-device-deployments.test.cjs"
  },
  "dependencies": {
    "@alicloud/ecs20140526": "^5.0.0",
    "@alicloud/openapi-client": "^0.4.15",
    "@alicloud/tea-util": "^1.4.8",
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "bullmq": "^5.56.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "ioredis": "^5.7.0",
    "pg": "^8.13.3",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/ioredis": "^4.28.10",
    "@types/node": "^22.13.13",
    "@types/pg": "^8.11.11",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.2"
  }
}
