{
  "name": "@xiaolanbu/desktop",
  "private": true,
  "version": "0.1.0",
  "description": "Xiaolanbu desktop shell",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1 --port 4177",
    "dev:electron": "wait-on tcp:4177 && cross-env XLB_DEV_URL=http://127.0.0.1:4177 electron .",
    "build": "vite build --outDir app-dist",
    "start": "npm run build && electron .",
    "preview": "vite preview --host 127.0.0.1 --port 4177",
    "smoke:local-chat": "node electron/smoke-local-chat.js",
    "selftest": "electron electron/selftest.js",
    "selftest:detect": "electron electron/selftest.js detect",
    "selftest:status": "electron electron/selftest.js status",
    "selftest:smoke-chat": "electron electron/selftest.js smoke-chat"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.1.5",
    "playwright": "^1.58.2",
    "vite": "^6.2.1",
    "wait-on": "^8.0.3"
  },
  "dependencies": {
    "dompurify": "^3.3.2",
    "marked": "^17.0.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "ssh2": "^1.17.0",
    "ws": "^8.19.0"
  }
}
